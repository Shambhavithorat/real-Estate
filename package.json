{
  "name": "real-estate-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@craco/craco": "^7.1.0",
    "axios": "^1.6.0",
    "firebase": "^12.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5"
  },
  "scripts": {
    "start": "npm run tailwind:build && react-scripts start",
    "tailwind:build": "npx tailwindcss -i src/index.css -o public/tailwind.css --content \"src/**/*.{js,jsx}\"",
    "tailwind:watch": "npx tailwindcss -i src/index.css -o public/tailwind.css --content \"src/**/*.{js,jsx}\" --watch",
    "build": "npm run tailwind:build && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
